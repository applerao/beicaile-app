# 被裁了吗 Python 后端 - 环境变量配置

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库配置（默认 SQLite）
DB_TYPE=sqlite
DATABASE_URL=sqlite+aiosqlite:///./data/beicaile.db

# PostgreSQL 配置（可选，当使用 PostgreSQL 时）
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=beicaile
# DB_USER=postgres
# DB_PASSWORD=postgres

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=7
